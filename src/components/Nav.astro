---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/dataviz', label: 'Data Viz' },
  { href: '/photos', label: 'Photos' },
  { href: '/writing', label: 'Writing' },
  { href: '/#contact', label: 'Contact' },
];
---

<nav class="nav">
  <div class="nav__inner container">
    <a href="/" class="nav__logo">wbs</a>
    <ul class="nav__links-desktop" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav__link', { 'nav__link--active': currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <button class="nav__toggle" aria-label="Open menu">
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<dialog class="nav__dialog" id="nav-dialog">
  <div class="nav__dialog-header">
    <button class="nav__dialog-close" aria-label="Close menu">
      <span></span>
      <span></span>
    </button>
  </div>
  <ul class="nav__dialog-links" role="list">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class:list={['nav__link', { 'nav__link--active': currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</dialog>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(6, 6, 11, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-size: var(--size-xl);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .nav__logo:hover {
    color: var(--cyan);
  }

  .nav__links-desktop {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
  }

  .nav__link {
    font-family: var(--font-display);
    font-size: var(--size-sm);
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.01em;
    padding: var(--space-xs) 0;
    position: relative;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--cyan);
    transition: width 0.3s;
  }

  .nav__link:hover {
    color: var(--text-primary);
  }

  .nav__link:hover::after {
    width: 100%;
  }

  .nav__link--active {
    color: var(--cyan);
  }

  .nav__link--active::after {
    width: 100%;
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-xs);
  }

  .nav__toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-primary);
  }

  /* Dialog (mobile menu) */
  .nav__dialog {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: var(--space-2xl);
    background: var(--bg-deep);
    border: none;
    color: var(--text-primary);
    z-index: 200;
  }

  .nav__dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
  }

  .nav__dialog-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: var(--space-3xl);
  }

  .nav__dialog-close {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-xs);
  }

  .nav__dialog-close span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-primary);
  }

  .nav__dialog-close span:first-child {
    transform: translateY(1px) rotate(45deg);
  }

  .nav__dialog-close span:last-child {
    transform: translateY(-1px) rotate(-45deg);
  }

  .nav__dialog-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .nav__dialog-links .nav__link {
    font-size: var(--size-2xl);
  }

  @media (max-width: 768px) {
    .nav__toggle {
      display: flex;
    }

    .nav__links-desktop {
      display: none;
    }
  }

  @media (min-width: 769px) {
    .nav__dialog {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav__toggle') as HTMLButtonElement;
  const dialog = document.getElementById('nav-dialog') as HTMLDialogElement;
  const close = dialog?.querySelector('.nav__dialog-close') as HTMLButtonElement;

  toggle?.addEventListener('click', () => {
    dialog?.showModal();
  });

  close?.addEventListener('click', () => {
    dialog?.close();
  });

  dialog?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      dialog.close();
    });
  });
</script>
