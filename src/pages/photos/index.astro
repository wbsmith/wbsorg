---
import Base from '../../layouts/Base.astro';
---

<Base title="Photos — W. Bryan Smith">
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="section__label">Photography</span>
        <h1 class="section__title">Photos</h1>
        <p class="photos__intro">
          Landscapes, macro, and abstract photography — a curated selection
          of work that made me stop moving. The full gallery lives at
          <a href="https://picgraf.com" target="_blank" rel="noopener">picgraf.com</a>.
        </p>
        <hr class="section__divider" />
      </div>
      <div class="photos__grid" id="photos-grid">
        {[0,1,2,3,4,5].map(i => (
          <div class="photos__slot" data-slot={i}>
            <div class="photos__empty-slot"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <dialog class="photos__modal" id="photos-modal">
    <div class="photos__modal-header">
      <button class="photos__modal-close" id="photos-modal-close" aria-label="Close">&times;</button>
    </div>
    <div class="photos__modal-body" id="photos-modal-body"></div>
  </dialog>
</Base>

<script>
  import { api } from '../../lib/api-client';

  async function loadPhotos() {
    try {
      const data = await api.getContent('photos');
      if (!data.content?.slots) return;
      data.content.slots.forEach((url: string, i: number) => {
        if (!url) return;
        const slot = document.querySelector(`[data-slot="${i}"]`);
        if (!slot) return;
        slot.innerHTML = `<img src="${url}" alt="Photo ${i + 1}" loading="lazy" />`;
        slot.classList.add('photos__slot--filled');
        slot.setAttribute('data-photo-url', url);
      });
    } catch {}
  }

  const modal = document.getElementById('photos-modal') as HTMLDialogElement;
  const modalBody = document.getElementById('photos-modal-body')!;
  const modalClose = document.getElementById('photos-modal-close')!;

  document.getElementById('photos-grid')!.addEventListener('click', (e) => {
    const slot = (e.target as HTMLElement).closest('.photos__slot--filled') as HTMLElement | null;
    if (!slot) return;
    const url = slot.getAttribute('data-photo-url')!;
    modalBody.innerHTML = `<img src="${url}" alt="" />`;
    modal.showModal();
  });

  modalClose.addEventListener('click', () => { modalBody.innerHTML = ''; modal.close(); });
  modal.addEventListener('click', (e) => { if (e.target === modal) { modalBody.innerHTML = ''; modal.close(); } });

  loadPhotos();
</script>

<style is:global>
  .photos__intro {
    font-size: var(--size-lg);
    color: var(--text-secondary);
    max-width: 40rem;
    margin-top: var(--space-md);
  }

  .photos__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  @media (max-width: 1024px) {
    .photos__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .photos__grid { grid-template-columns: 1fr; }
  }

  .photos__slot {
    aspect-ratio: 3 / 2;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
  }

  .photos__slot--filled { cursor: pointer; }

  .photos__slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .photos__slot--filled:hover img {
    transform: scale(1.03);
  }

  .photos__empty-slot {
    width: 100%;
    height: 100%;
    background: var(--bg-surface);
  }

  .photos__modal {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: rgba(6, 6, 11, 0.95);
    z-index: 300;
  }

  .photos__modal::backdrop { background: transparent; }

  .photos__modal-header {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    z-index: 10;
  }

  .photos__modal-close {
    font-size: 2rem;
    color: var(--text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
    padding: var(--space-sm);
  }

  .photos__modal-close:hover { color: var(--text-primary); }

  .photos__modal-body {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3xl);
  }

  .photos__modal-body img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: var(--radius-md);
  }
</style>
