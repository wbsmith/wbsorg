---
import Base from '../../layouts/Base.astro';
---

<Base title="Photos — W. Bryan Smith">
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="section__label">Photography</span>
        <h1 class="section__title">Photos</h1>
        <p class="photos__intro">
          Landscapes, macro, and abstract photography — a curated selection
          of work that made me stop moving. The full gallery lives at
          <a href="https://picgraf.com" target="_blank" rel="noopener">picgraf.com</a>.
        </p>
        <hr class="section__divider" />
      </div>
      <div class="photos__grid">
        <div class="photos__slot" data-slot="0">
          <div class="photos__empty-slot"></div>
        </div>
        <div class="photos__slot" data-slot="1">
          <div class="photos__empty-slot"></div>
        </div>
        <div class="photos__slot" data-slot="2">
          <div class="photos__empty-slot"></div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { api } from '../../lib/api-client';

  async function loadPhotos() {
    try {
      const data = await api.getContent('photos');
      if (!data.content?.slots) return;
      data.content.slots.forEach((url: string, i: number) => {
        if (!url) return;
        const slot = document.querySelector(`[data-slot="${i}"]`);
        if (slot) slot.innerHTML = `<img src="${url}" alt="Photo ${i + 1}" loading="lazy" />`;
      });
    } catch { /* keep empty slots */ }
  }
  loadPhotos();
</script>

<style is:global>
  .photos__intro {
    font-size: var(--size-lg);
    color: var(--text-secondary);
    max-width: 40rem;
    margin-top: var(--space-md);
  }

  .photos__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .photos__grid {
      grid-template-columns: 1fr;
    }
  }

  .photos__slot {
    aspect-ratio: 3 / 2;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
  }

  .photos__slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photos__empty-slot {
    width: 100%;
    height: 100%;
    background: var(--bg-surface);
  }
</style>
