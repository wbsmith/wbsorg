---
import Base from '../../layouts/Base.astro';
import { AWS_CONFIG } from '../../lib/aws-config';

const defaultProjects = [
  { name: 'Userdata.io', url: 'https://userdata.io', accent: 'cyan', description: 'Identity infrastructure for individuals and enterprises.', tags: ['Privacy', 'Identity', 'APIs', 'Data Rights'] },
  { name: 'NewsReal.ai', url: 'https://newsreal.ai', accent: 'magenta', description: 'AI-powered news aggregation and analysis.', tags: ['AI', 'NLP', 'News', 'Analysis'] },
  { name: 'Picgraf', url: 'https://picgraf.com', accent: 'amber', description: 'A web-based photo gallery for my photography work.', tags: ['Photography', 'Gallery', 'Web'] },
  { name: 'World in Wonder', url: 'https://worldinwonder.com', accent: 'coral', description: 'Nature-based programs for young explorers.', tags: ['Education', 'Nature', 'Youth Programs'] },
];

let pageTitle = "Things I've built";
let pageSubtitle = "Independent products I've created outside of my day job, each addressing a problem I wanted solved.";
let projects = defaultProjects;

try {
  const res = await fetch(`${AWS_CONFIG.apiUrl}/api/content/projects`);
  if (res.ok) {
    const data = await res.json();
    if (data.content) {
      pageTitle = data.content.title || pageTitle;
      pageSubtitle = data.content.subtitle || pageSubtitle;
      if (data.content.projects?.length) projects = data.content.projects;
    }
  }
} catch {}
---

<Base title="Projects — W. Bryan Smith">
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="section__label">Projects</span>
        <h1 class="section__title">{pageTitle}</h1>
        <p class="projects__intro">{pageSubtitle}</p>
        <hr class="section__divider" />
      </div>
      <div class="projects__grid" id="projects-grid">
        {projects.map(project => (
          <a href={project.url} target="_blank" rel="noopener" class="project-card">
            <div class={`project-card__accent project-card__accent--${project.accent}`}></div>
            <div class="project-card__body">
              <h2 class="project-card__name">{project.name}</h2>
              <p class="project-card__desc">{project.description}</p>
              <div class="project-card__tags">
                {project.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <span class="project-card__link">
                {project.url.replace('https://', '')} &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  import { api } from '../../lib/api-client';

  async function refreshProjects() {
    try {
      const data = await api.getContent('projects');
      const c = data.content;
      if (!c?.projects?.length) return;

      const grid = document.getElementById('projects-grid');
      if (grid) {
        grid.innerHTML = c.projects.map((p: any) => `
          <a href="${p.url}" target="_blank" rel="noopener" class="project-card">
            <div class="project-card__accent project-card__accent--${p.accent || 'cyan'}"></div>
            <div class="project-card__body">
              <h2 class="project-card__name">${p.name}</h2>
              <p class="project-card__desc">${p.description}</p>
              <div class="project-card__tags">
                ${(Array.isArray(p.tags) ? p.tags : []).map((t: string) => `<span class="tag">${t}</span>`).join('')}
              </div>
              <span class="project-card__link">${p.url.replace('https://', '')} &rarr;</span>
            </div>
          </a>
        `).join('');
      }
    } catch {}
  }
  refreshProjects();
</script>

<style is:global>
  .projects__intro {
    font-size: var(--size-lg);
    color: var(--text-secondary);
    max-width: 40rem;
    margin-top: var(--space-md);
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  @media (max-width: 768px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }
  }

  .project-card {
    display: flex;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.3s, background-color 0.3s, transform 0.2s;
    color: inherit;
  }

  .project-card:hover {
    border-color: var(--border-medium);
    background: var(--bg-elevated);
    transform: translateY(-2px);
    color: inherit;
  }

  .project-card__accent {
    width: 4px;
    flex-shrink: 0;
  }

  .project-card__accent--cyan { background: var(--cyan); }
  .project-card__accent--magenta { background: var(--magenta); }
  .project-card__accent--amber { background: var(--amber); }
  .project-card__accent--coral { background: var(--coral); }

  .project-card__body {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .project-card__name {
    font-size: var(--size-2xl);
  }

  .project-card__desc {
    color: var(--text-secondary);
    font-size: var(--size-base);
    line-height: 1.7;
    flex: 1;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .project-card__link {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .project-card:hover .project-card__link {
    color: var(--cyan);
  }
</style>
