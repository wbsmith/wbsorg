---
import '../../styles/global.css';
import '../../styles/admin.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <link rel="icon" href="/favicon.ico" />
  <title>Admin — W. Bryan Smith</title>
  <link href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked@15/marked.min.js"></script>
</head>
<body>

<!-- Login -->
<div id="login-view" class="admin-login" style="display:none;">
  <h1>Admin</h1>
  <form id="login-form" action="/admin" method="post">
    <div class="admin-login__field">
      <label for="login-email">Email</label>
      <input type="email" id="login-email" name="email" required autocomplete="username" />
    </div>
    <div class="admin-login__field">
      <label for="login-password">Password</label>
      <input type="password" id="login-password" name="password" required autocomplete="current-password" />
    </div>
    <button type="submit" class="admin-btn">Sign In</button>
    <p id="login-error" class="admin-error" style="display:none;"></p>
  </form>
  <!-- New password form (Cognito first login) -->
  <form id="new-password-form" style="display:none;">
    <p style="color:var(--text-secondary);margin-bottom:var(--space-md);">Set a new password:</p>
    <div class="admin-login__field">
      <label for="new-password">New Password</label>
      <input type="password" id="new-password" required minlength="12" autocomplete="new-password" />
    </div>
    <button type="submit" class="admin-btn">Set Password</button>
    <p id="new-password-error" class="admin-error" style="display:none;"></p>
  </form>
</div>

<!-- Dashboard -->
<div id="dashboard-view" style="display:none;">
  <nav class="nav" style="position:relative;">
    <div class="nav__inner container">
      <a href="/" class="nav__logo">wbs</a>
      <span style="font-family:var(--font-mono);font-size:var(--size-xs);color:var(--text-muted);">admin</span>
    </div>
  </nav>
  <div class="admin-dashboard">
    <aside class="admin-sidebar">
      <button class="admin-sidebar__link admin-sidebar__link--active" data-section="home">Home</button>
      <button class="admin-sidebar__link" data-section="projects">Projects</button>
      <button class="admin-sidebar__link" data-section="photos">Photos</button>
      <button class="admin-sidebar__link" data-section="dataviz">Data Viz</button>
      <button class="admin-sidebar__link" data-section="writing">Writing</button>
      <button class="admin-sidebar__link" data-section="messages">Messages</button>
      <button class="admin-sidebar__signout" id="signout-btn">Sign out</button>
    </aside>
    <div class="admin-main">

      <!-- Home editor -->
      <div class="admin-section admin-section--active" id="section-home">
        <h2>Home Page</h2>
        <div class="admin-field">
          <label for="edit-heroLabel">Hero Label</label>
          <input type="text" id="edit-heroLabel" />
        </div>
        <div class="admin-field">
          <label for="edit-heroTitle">Hero Title (use Enter for line breaks, last line gets the gradient)</label>
          <textarea id="edit-heroTitle" rows="3"></textarea>
        </div>
        <div class="admin-field">
          <label for="edit-heroSub">Hero Subtitle</label>
          <textarea id="edit-heroSub" rows="3"></textarea>
        </div>
        <div class="admin-field">
          <label for="edit-aboutP1">About — Paragraph 1</label>
          <textarea id="edit-aboutP1" rows="5"></textarea>
        </div>
        <div class="admin-field">
          <label for="edit-aboutP2">About — Paragraph 2</label>
          <textarea id="edit-aboutP2" rows="5"></textarea>
        </div>
        <div class="admin-field">
          <label for="edit-aboutP3">About — Paragraph 3</label>
          <textarea id="edit-aboutP3" rows="5"></textarea>
        </div>
        <h3 style="margin-top:var(--space-2xl);margin-bottom:var(--space-lg);padding-top:var(--space-xl);border-top:1px solid var(--border-subtle);">Career Roles</h3>
        <div id="roles-editor"></div>
        <button class="admin-btn admin-btn--small" id="add-role" style="margin-top:var(--space-md);">+ Add Role</button>

        <h3 style="margin-top:var(--space-2xl);margin-bottom:var(--space-lg);padding-top:var(--space-xl);border-top:1px solid var(--border-subtle);">Expertise Cards</h3>
        <div id="expertise-editor"></div>
        <button class="admin-btn admin-btn--small" id="add-expertise" style="margin-top:var(--space-md);">+ Add Card</button>

        <div style="margin-top:var(--space-2xl);">
          <button class="admin-btn" id="save-home">Save</button>
          <p id="home-status" style="display:none;"></p>
        </div>
      </div>

      <!-- Projects editor -->
      <div class="admin-section" id="section-projects">
        <h2>Projects</h2>
        <div id="projects-editor"></div>
        <div style="display:flex;gap:var(--space-md);margin-top:var(--space-xl);">
          <button class="admin-btn" id="save-projects">Save</button>
          <button class="admin-btn admin-btn--small" id="add-project">+ Add Project</button>
        </div>
        <p id="projects-status" style="display:none;"></p>
      </div>

      <!-- Photos manager -->
      <div class="admin-section" id="section-photos">
        <h2>Photos</h2>
        <p style="color:var(--text-secondary);margin-bottom:var(--space-xl);">Drag and drop images into the 3 slots below.</p>
        <div class="admin-slots admin-slots--6" id="photo-slots"></div>
        <button class="admin-btn" id="save-photos" style="margin-top:var(--space-xl);">Save</button>
        <p id="photos-status" style="display:none;"></p>
      </div>

      <!-- DataViz manager -->
      <div class="admin-section" id="section-dataviz">
        <h2>Data Viz</h2>
        <p style="color:var(--text-secondary);margin-bottom:var(--space-xl);">Drag and drop images or videos into the 6 slots below.</p>
        <div class="admin-slots admin-slots--6" id="dataviz-slots"></div>
        <button class="admin-btn" id="save-dataviz" style="margin-top:var(--space-xl);">Save</button>
        <p id="dataviz-status" style="display:none;"></p>
      </div>

      <!-- Writing / Blog editor -->
      <div class="admin-section" id="section-writing">
        <h2>Writing</h2>

        <!-- Post list -->
        <div id="posts-list-view">
          <button class="admin-btn" id="new-post-btn" style="margin-bottom:var(--space-xl);">New Post</button>
          <div id="posts-list">
            <p style="color:var(--text-muted);font-family:var(--font-mono);font-size:var(--size-sm);">Loading...</p>
          </div>
        </div>

        <!-- Post editor -->
        <div id="post-editor-view" style="display:none;">
          <button class="admin-btn admin-btn--small" id="back-to-posts" style="margin-bottom:var(--space-xl);">&larr; Back to posts</button>
          <div class="admin-field">
            <label for="post-title">Title</label>
            <input type="text" id="post-title" />
          </div>
          <div class="admin-field">
            <label for="post-excerpt">Excerpt (shown in post list)</label>
            <textarea id="post-excerpt" rows="2"></textarea>
          </div>
          <div class="admin-field">
            <label>Body</label>
            <div style="margin-bottom:var(--space-sm);">
              <button class="admin-btn admin-btn--small" id="toggle-editor-mode" type="button">Switch to Markdown</button>
            </div>
            <div id="quill-wrapper">
              <div id="post-editor-toolbar"></div>
              <div id="post-editor" style="min-height:300px;background:var(--bg-surface);color:var(--text-primary);border:1px solid var(--border-subtle);border-top:none;border-radius:0 0 var(--radius-sm) var(--radius-sm);"></div>
            </div>
            <textarea id="markdown-editor" style="display:none;min-height:400px;width:100%;background:var(--bg-surface);color:var(--text-primary);border:1px solid var(--border-subtle);border-radius:var(--radius-sm);padding:var(--space-md);font-family:var(--font-mono);font-size:var(--size-sm);line-height:1.7;resize:vertical;"></textarea>
          </div>
          <div class="admin-field">
            <label for="post-status">Status</label>
            <select id="post-status" style="background:var(--bg-surface);border:1px solid var(--border-subtle);border-radius:var(--radius-sm);padding:var(--space-sm) var(--space-md);color:var(--text-primary);font-size:var(--size-base);">
              <option value="draft">Draft</option>
              <option value="published">Published</option>
            </select>
          </div>
          <div style="display:flex;gap:var(--space-md);align-items:center;">
            <button class="admin-btn" id="save-post-btn">Save</button>
            <button class="admin-btn admin-btn--small admin-btn--danger" id="delete-post-btn" style="display:none;">Delete</button>
            <span id="post-save-status" style="font-family:var(--font-mono);font-size:var(--size-sm);display:none;"></span>
          </div>
        </div>
      </div>

      <!-- Messages -->
      <div class="admin-section" id="section-messages">
        <h2>Messages</h2>
        <div id="messages-container">
          <p style="color:var(--text-muted);font-family:var(--font-mono);font-size:var(--size-sm);">Loading...</p>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  import { isAuthenticated, signIn, signOut, completeNewPassword } from '../../lib/auth';
  import { api } from '../../lib/api-client';

  const loginView = document.getElementById('login-view')!;
  const dashboardView = document.getElementById('dashboard-view')!;

  // ── Auth ──
  function showView() {
    if (isAuthenticated()) {
      loginView.style.display = 'none';
      dashboardView.style.display = 'block';
      loadSection('home');
    } else {
      loginView.style.display = 'block';
      dashboardView.style.display = 'none';
    }
  }

  let pendingSession = '';
  let pendingEmail = '';

  document.getElementById('login-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('login-email') as HTMLInputElement).value;
    const password = (document.getElementById('login-password') as HTMLInputElement).value;
    const errEl = document.getElementById('login-error')!;
    errEl.style.display = 'none';

    const result = await signIn(email, password);
    if (result.success) {
      if (window.PasswordCredential) {
        const cred = new PasswordCredential({ id: email, password: password });
        navigator.credentials.store(cred).catch(() => {});
      }
      showView();
    } else if (result.challenge === 'NEW_PASSWORD_REQUIRED') {
      pendingSession = result.session!;
      pendingEmail = email;
      document.getElementById('login-form')!.style.display = 'none';
      document.getElementById('new-password-form')!.style.display = 'block';
    } else {
      errEl.textContent = result.error || 'Sign in failed';
      errEl.style.display = 'block';
    }
  });

  document.getElementById('new-password-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const newPw = (document.getElementById('new-password') as HTMLInputElement).value;
    const errEl = document.getElementById('new-password-error')!;
    errEl.style.display = 'none';

    const result = await completeNewPassword(pendingSession, pendingEmail, newPw);
    if (result.success) {
      showView();
    } else {
      errEl.textContent = result.error || 'Failed';
      errEl.style.display = 'block';
    }
  });

  document.getElementById('signout-btn')!.addEventListener('click', () => {
    signOut();
    showView();
  });

  // ── Sidebar navigation ──
  const sidebarLinks = document.querySelectorAll<HTMLButtonElement>('.admin-sidebar__link');
  const sections = document.querySelectorAll<HTMLDivElement>('.admin-section');

  sidebarLinks.forEach(link => {
    link.addEventListener('click', () => {
      const section = link.getAttribute('data-section')!;
      sidebarLinks.forEach(l => l.classList.remove('admin-sidebar__link--active'));
      link.classList.add('admin-sidebar__link--active');
      sections.forEach(s => s.classList.remove('admin-section--active'));
      document.getElementById(`section-${section}`)?.classList.add('admin-section--active');
      loadSection(section);
    });
  });

  // ── Section loaders ──
  const loadedSections = new Set<string>();

  async function loadSection(section: string) {
    if (loadedSections.has(section)) return;
    loadedSections.add(section);

    if (section === 'home') await loadHomeEditor();
    if (section === 'projects') await loadProjectsEditor();
    if (section === 'photos') renderSlots('photo-slots', 6, 'photos');
    if (section === 'dataviz') renderSlots('dataviz-slots', 6, 'dataviz');
    if (section === 'writing') await loadPostsList();
    if (section === 'messages') await loadMessages();
  }

  // ── Home editor ──
  let homeRoles: any[] = [];
  let homeExpertise: any[] = [];

  function renderListEditor(containerId: string, items: any[], fields: {key: string, label: string, type?: string}[], onUpdate: (items: any[]) => void) {
    const container = document.getElementById(containerId)!;
    container.innerHTML = items.map((item, i) => `
      <div style="border:1px solid var(--border-subtle);border-radius:var(--radius-md);padding:var(--space-md);margin-bottom:var(--space-md);">
        ${fields.map(f => `
          <div class="admin-field" style="margin-bottom:var(--space-sm);">
            <label>${f.label}</label>
            ${f.type === 'textarea'
              ? `<textarea data-list-field="${f.key}" data-list-index="${i}" rows="2">${item[f.key] || ''}</textarea>`
              : `<input type="text" data-list-field="${f.key}" data-list-index="${i}" value="${(item[f.key] || '').replace(/"/g, '&quot;')}" />`}
          </div>
        `).join('')}
        <button class="admin-btn admin-btn--small admin-btn--danger" data-list-remove="${i}">Remove</button>
      </div>
    `).join('');

    container.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[data-list-field]').forEach(el => {
      el.addEventListener('input', () => {
        items[parseInt(el.dataset.listIndex!)][el.dataset.listField!] = el.value;
        onUpdate(items);
      });
    });
    container.querySelectorAll<HTMLButtonElement>('[data-list-remove]').forEach(btn => {
      btn.addEventListener('click', () => {
        items.splice(parseInt(btn.dataset.listRemove!), 1);
        onUpdate(items);
        renderListEditor(containerId, items, fields, onUpdate);
      });
    });
  }

  const roleFields = [
    { key: 'date', label: 'Date Range' },
    { key: 'role', label: 'Role Title' },
    { key: 'org', label: 'Organization' },
    { key: 'desc', label: 'Description', type: 'textarea' as const },
    { key: 'accent', label: 'Accent Color (cyan/magenta/amber/coral/blue)' },
  ];

  const expertiseFields = [
    { key: 'title', label: 'Title' },
    { key: 'desc', label: 'Description', type: 'textarea' as const },
    { key: 'tags', label: 'Tags (comma-separated)' },
    { key: 'accent', label: 'Accent Color (cyan/magenta/amber)' },
  ];

  async function loadHomeEditor() {
    try {
      const data = await api.getContent('home');
      const c = data.content;
      (document.getElementById('edit-heroLabel') as HTMLInputElement).value = c.heroLabel || '';
      (document.getElementById('edit-heroTitle') as HTMLInputElement).value = c.heroTitle || '';
      (document.getElementById('edit-heroSub') as HTMLTextAreaElement).value = c.heroSub || '';
      const paragraphs = c.aboutParagraphs || [];
      (document.getElementById('edit-aboutP1') as HTMLTextAreaElement).value = paragraphs[0] || '';
      (document.getElementById('edit-aboutP2') as HTMLTextAreaElement).value = paragraphs[1] || '';
      (document.getElementById('edit-aboutP3') as HTMLTextAreaElement).value = paragraphs[2] || '';

      homeRoles = (c.roles || []).map((r: any) => ({...r}));
      homeExpertise = (c.expertise || []).map((e: any) => ({
        ...e,
        tags: Array.isArray(e.tags) ? e.tags.join(', ') : e.tags || '',
      }));

      renderListEditor('roles-editor', homeRoles, roleFields, (items) => { homeRoles = items; });
      renderListEditor('expertise-editor', homeExpertise, expertiseFields, (items) => { homeExpertise = items; });
    } catch {}
  }

  document.getElementById('add-role')!.addEventListener('click', () => {
    homeRoles.push({ date: '', role: '', org: '', desc: '', accent: 'cyan' });
    renderListEditor('roles-editor', homeRoles, roleFields, (items) => { homeRoles = items; });
  });

  document.getElementById('add-expertise')!.addEventListener('click', () => {
    homeExpertise.push({ title: '', desc: '', tags: '', accent: 'cyan' });
    renderListEditor('expertise-editor', homeExpertise, expertiseFields, (items) => { homeExpertise = items; });
  });

  document.getElementById('save-home')!.addEventListener('click', async () => {
    const statusEl = document.getElementById('home-status')!;
    try {
      await api.putContent('home', {
        heroLabel: (document.getElementById('edit-heroLabel') as HTMLInputElement).value,
        heroTitle: (document.getElementById('edit-heroTitle') as HTMLInputElement).value,
        heroSub: (document.getElementById('edit-heroSub') as HTMLTextAreaElement).value,
        aboutParagraphs: [
          (document.getElementById('edit-aboutP1') as HTMLTextAreaElement).value,
          (document.getElementById('edit-aboutP2') as HTMLTextAreaElement).value,
          (document.getElementById('edit-aboutP3') as HTMLTextAreaElement).value,
        ],
        roles: homeRoles,
        expertise: homeExpertise.map(e => ({
          ...e,
          tags: typeof e.tags === 'string' ? e.tags.split(',').map((t: string) => t.trim()).filter(Boolean) : e.tags,
        })),
      });
      statusEl.textContent = 'Saved.';
      statusEl.className = 'admin-success';
      statusEl.style.display = 'block';
    } catch (err: any) {
      statusEl.textContent = err.message;
      statusEl.className = 'admin-error';
      statusEl.style.display = 'block';
    }
  });

  // ── Projects editor ──
  let projectsList: any[] = [];
  const projectFields = [
    { key: 'name', label: 'Name' },
    { key: 'url', label: 'URL' },
    { key: 'description', label: 'Description', type: 'textarea' as const },
    { key: 'tags', label: 'Tags (comma-separated)' },
    { key: 'accent', label: 'Accent Color (cyan/magenta/amber/coral)' },
  ];

  async function loadProjectsEditor() {
    try {
      const data = await api.getContent('projects');
      projectsList = (data.content?.projects || []).map((p: any) => ({
        ...p,
        tags: Array.isArray(p.tags) ? p.tags.join(', ') : p.tags || '',
      }));
      renderListEditor('projects-editor', projectsList, projectFields, (items) => { projectsList = items; });
    } catch {}
  }

  document.getElementById('add-project')!.addEventListener('click', () => {
    projectsList.push({ name: '', url: '', description: '', tags: '', accent: 'cyan' });
    renderListEditor('projects-editor', projectsList, projectFields, (items) => { projectsList = items; });
  });

  document.getElementById('save-projects')!.addEventListener('click', async () => {
    const statusEl = document.getElementById('projects-status')!;
    try {
      await api.putContent('projects', {
        title: "Things I've built",
        subtitle: "Independent products I've created outside of my day job, each addressing a problem I wanted solved.",
        projects: projectsList.map(p => ({
          ...p,
          tags: typeof p.tags === 'string' ? p.tags.split(',').map((t: string) => t.trim()).filter(Boolean) : p.tags,
        })),
      });
      statusEl.textContent = 'Saved.'; statusEl.className = 'admin-success'; statusEl.style.display = '';
    } catch (err: any) {
      statusEl.textContent = err.message; statusEl.className = 'admin-error'; statusEl.style.display = '';
    }
  });

  // ── Slot manager (photos + dataviz) ──
  interface SlotItem { url: string; caption: string; description: string; width: number; height: number; }
  const slotData: Record<string, (SlotItem | null)[]> = {};
  const slotDataLoaded = new Set<string>();
  const showCaptions: Record<string, boolean> = { photos: false, dataviz: true };

  function renderSlots(containerId: string, count: number, pageId: string) {
    const container = document.getElementById(containerId)!;
    if (!slotData[pageId]) slotData[pageId] = new Array(count).fill(null);
    container.innerHTML = '';

    for (let i = 0; i < count; i++) {
      const slot = document.createElement('div');
      slot.className = 'admin-slot';
      const item = slotData[pageId][i];
      const url = item?.url;

      let preview = '';
      let dropContent = '';
      const iw = item?.width || 1024;
      const ih = item?.height || 768;
      if (url) {
        if (/\.html?$/i.test(url)) {
          preview = `<div class="admin-slot__iframe-wrap" style="--iframe-w:${iw}px;--iframe-h:${ih}px;"><iframe src="${url}"></iframe></div>`;
        } else if (/\.(mp4|webm|mov)$/i.test(url)) {
          preview = `<video src="${url}" muted loop autoplay playsinline style="width:100%;height:100%;object-fit:contain;"></video>`;
        } else {
          preview = `<img src="${url}" alt="Slot ${i+1}" />`;
        }
      } else {
        dropContent = `<p>Drop file here</p>
          <input type="file" accept="image/*,video/*,.html,.htm,.svg" data-file-index="${i}" data-file-page="${pageId}" />`;
      }

      const captionField = (url && showCaptions[pageId]) ? `
        <div class="admin-field" style="margin:0;padding:var(--space-sm);">
          <input type="text" placeholder="Caption..." value="${item?.caption || ''}" data-caption-index="${i}" data-caption-page="${pageId}" style="font-size:var(--size-xs);" />
          <textarea placeholder="Description (shown in fullscreen)..." data-desc-index="${i}" data-desc-page="${pageId}" rows="2" style="font-size:var(--size-xs);margin-top:var(--space-xs);width:100%;background:var(--bg-surface);border:1px solid var(--border-subtle);border-radius:var(--radius-sm);padding:var(--space-xs) var(--space-sm);color:var(--text-primary);resize:vertical;">${item?.description || ''}</textarea>
        </div>` : '';

      slot.innerHTML = `
        <div class="admin-slot__preview ${url ? '' : 'admin-dropzone'}" data-drop-index="${i}" data-drop-page="${pageId}">
          ${preview || dropContent}
        </div>
        ${captionField}
        <div class="admin-slot__actions">
          ${url ? `<button class="admin-btn admin-btn--small admin-btn--danger" data-clear-index="${i}" data-clear-page="${pageId}">Remove</button>` : ''}
        </div>
      `;
      container.appendChild(slot);
    }

    // Drag-and-drop + file input handlers
    container.querySelectorAll<HTMLDivElement>('.admin-dropzone').forEach(zone => {
      zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.classList.add('dragover'); });
      zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
      zone.addEventListener('drop', async (e) => {
        e.preventDefault();
        zone.classList.remove('dragover');
        const file = e.dataTransfer?.files[0];
        if (file) await uploadToSlot(file, zone.dataset.dropPage!, parseInt(zone.dataset.dropIndex!), containerId);
      });
    });

    container.querySelectorAll<HTMLInputElement>('input[type="file"]').forEach(input => {
      input.addEventListener('change', async () => {
        const file = input.files?.[0];
        if (file) await uploadToSlot(file, input.dataset.filePage!, parseInt(input.dataset.fileIndex!), containerId);
      });
    });

    container.querySelectorAll<HTMLInputElement>('[data-caption-index]').forEach(input => {
      input.addEventListener('input', () => {
        const pg = input.dataset.captionPage!;
        const idx = parseInt(input.dataset.captionIndex!);
        if (slotData[pg][idx]) slotData[pg][idx]!.caption = input.value;
      });
    });

    container.querySelectorAll<HTMLTextAreaElement>('[data-desc-index]').forEach(ta => {
      ta.addEventListener('input', () => {
        const pg = ta.dataset.descPage!;
        const idx = parseInt(ta.dataset.descIndex!);
        if (slotData[pg][idx]) slotData[pg][idx]!.description = ta.value;
      });
    });

    container.querySelectorAll<HTMLButtonElement>('[data-clear-index]').forEach(btn => {
      btn.addEventListener('click', () => {
        const pg = btn.dataset.clearPage!;
        slotData[pg][parseInt(btn.dataset.clearIndex!)] = null;
        renderSlots(containerId, count, pg);
      });
    });

    // Scale iframes to fit slots
    container.querySelectorAll<HTMLDivElement>('.admin-slot__iframe-wrap').forEach(wrap => {
      const iframe = wrap.querySelector('iframe');
      if (!iframe) return;
      const doScale = () => {
        const w = wrap.clientWidth;
        const iw = parseInt(wrap.style.getPropertyValue('--iframe-w')) || 1024;
        if (w > 0) iframe.style.transform = `scale(${w / iw})`;
      };
      iframe.addEventListener('load', doScale);
      setTimeout(doScale, 100);
      window.addEventListener('resize', doScale);
    });

    // Load existing data (once)
    if (!slotDataLoaded.has(pageId)) {
      slotDataLoaded.add(pageId);
      api.getContent(pageId).then(data => {
        if (data.content?.slots) {
          slotData[pageId] = data.content.slots.map((s: any) => {
            if (!s) return null;
            if (typeof s === 'string') return { url: s, caption: '', description: '', width: 0, height: 0 };
            return { url: s.url, caption: s.caption || '', description: s.description || '', width: s.width || 0, height: s.height || 0 };
          });
          while (slotData[pageId].length < count) slotData[pageId].push(null);
          renderSlots(containerId, count, pageId);
        }
      }).catch(() => {});
    }
  }

  function detectDimensions(file: File): Promise<{ width: number; height: number }> {
    return new Promise((resolve) => {
      if (file.type.startsWith('image/')) {
        const img = new Image();
        img.onload = () => { resolve({ width: img.naturalWidth, height: img.naturalHeight }); URL.revokeObjectURL(img.src); };
        img.onerror = () => resolve({ width: 0, height: 0 });
        img.src = URL.createObjectURL(file);
      } else if (file.type.startsWith('video/')) {
        const vid = document.createElement('video');
        vid.onloadedmetadata = () => { resolve({ width: vid.videoWidth, height: vid.videoHeight }); URL.revokeObjectURL(vid.src); };
        vid.onerror = () => resolve({ width: 0, height: 0 });
        vid.src = URL.createObjectURL(file);
      } else if (file.name.match(/\.html?$/i)) {
        const reader = new FileReader();
        reader.onload = () => {
          const text = reader.result as string;
          const wMatch = text.match(/"width":\s*(\d+(?:\.\d+)?)/);
          const hMatch = text.match(/"height":\s*(\d+(?:\.\d+)?)/);
          if (wMatch && hMatch) {
            resolve({ width: Math.round(parseFloat(wMatch[1])), height: Math.round(parseFloat(hMatch[1])) });
          } else {
            resolve({ width: 1024, height: 768 });
          }
        };
        reader.onerror = () => resolve({ width: 1024, height: 768 });
        reader.readAsText(file);
      } else {
        resolve({ width: 0, height: 0 });
      }
    });
  }

  async function uploadToSlot(file: File, pageId: string, index: number, containerId: string) {
    try {
      const prefix = pageId === 'photos' ? 'photos' : 'dataviz';
      const [{ uploadUrl, publicUrl }, dims] = await Promise.all([
        api.getPresignedUrl(file.name, file.type, prefix),
        detectDimensions(file),
      ]);
      await fetch(uploadUrl, { method: 'PUT', body: file, headers: { 'Content-Type': file.type } });
      const prev = slotData[pageId][index];
      slotData[pageId][index] = {
        url: publicUrl,
        caption: prev?.caption || '',
        description: prev?.description || '',
        width: dims.width,
        height: dims.height,
      };
      renderSlots(containerId, 6, pageId);
    } catch (err: any) {
      alert('Upload failed: ' + err.message);
    }
  }

  // Save slots
  document.getElementById('save-photos')?.addEventListener('click', async () => {
    const statusEl = document.getElementById('photos-status')!;
    try {
      await api.putContent('photos', { slots: (slotData['photos'] || []).map(s => s?.url || null) });
      statusEl.textContent = 'Saved.'; statusEl.className = 'admin-success'; statusEl.style.display = 'block';
    } catch (err: any) {
      statusEl.textContent = err.message; statusEl.className = 'admin-error'; statusEl.style.display = 'block';
    }
  });

  document.getElementById('save-dataviz')?.addEventListener('click', async () => {
    const statusEl = document.getElementById('dataviz-status')!;
    try {
      await api.putContent('dataviz', { slots: slotData['dataviz'] || [] });
      statusEl.textContent = 'Saved.'; statusEl.className = 'admin-success'; statusEl.style.display = 'block';
    } catch (err: any) {
      statusEl.textContent = err.message; statusEl.className = 'admin-error'; statusEl.style.display = 'block';
    }
  });

  // ── Messages ──
  async function loadMessages() {
    const container = document.getElementById('messages-container')!;
    try {
      const data = await api.getMessages();
      const msgs = data.messages || [];
      if (msgs.length === 0) {
        container.innerHTML = '<p style="color:var(--text-muted);font-family:var(--font-mono);font-size:var(--size-sm);">No messages yet.</p>';
        return;
      }
      container.innerHTML = `<table class="admin-messages">
        <thead><tr><th>Date</th><th>From</th><th>Message</th><th></th></tr></thead>
        <tbody>${msgs.map((m: any) => `
          <tr class="${m.status === 'unread' ? 'unread' : ''}" data-msg-id="${m.messageId}">
            <td>${new Date(m.createdAt).toLocaleDateString()}</td>
            <td>${m.name}<br/><span style="font-size:var(--size-xs);color:var(--text-muted);">${m.email}</span></td>
            <td>${m.message.length > 120 ? m.message.slice(0, 120) + '...' : m.message}</td>
            <td class="admin-messages__actions">
              <button class="admin-btn admin-btn--small" data-toggle-msg="${m.messageId}" data-msg-status="${m.status}">${m.status === 'unread' ? 'Read' : 'Unread'}</button>
              <button class="admin-btn admin-btn--small admin-btn--danger" data-delete-msg="${m.messageId}">Del</button>
            </td>
          </tr>
        `).join('')}</tbody>
      </table>`;

      container.querySelectorAll<HTMLButtonElement>('[data-toggle-msg]').forEach(btn => {
        btn.addEventListener('click', async () => {
          const newStatus = btn.dataset.msgStatus === 'unread' ? 'read' : 'unread';
          await api.patchMessage(btn.dataset.toggleMsg!, newStatus);
          loadedSections.delete('messages');
          await loadMessages();
        });
      });

      container.querySelectorAll<HTMLButtonElement>('[data-delete-msg]').forEach(btn => {
        btn.addEventListener('click', async () => {
          if (!confirm('Delete this message?')) return;
          await api.deleteMessage(btn.dataset.deleteMsg!);
          loadedSections.delete('messages');
          await loadMessages();
        });
      });
    } catch (err: any) {
      container.innerHTML = `<p class="admin-error">${err.message}</p>`;
    }
  }

  // ── Blog / Writing ──
  let quillEditor: any = null;
  let editingPostId: string | null = null;
  let isMarkdownMode = false;
  let postSourceMarkdown = '';

  const postsListView = document.getElementById('posts-list-view')!;
  const postEditorView = document.getElementById('post-editor-view')!;
  const postsList = document.getElementById('posts-list')!;
  const quillWrapper = document.getElementById('quill-wrapper')!;
  const markdownEditor = document.getElementById('markdown-editor') as HTMLTextAreaElement;
  const toggleBtn = document.getElementById('toggle-editor-mode')!;

  function initQuill() {
    if (quillEditor) return;
    quillEditor = new (window as any).Quill('#post-editor', {
      theme: 'snow',
      modules: {
        toolbar: {
          container: [
            [{ header: [2, 3, false] }],
            ['bold', 'italic', 'underline'],
            [{ color: [] }],
            [{ align: [] }],
            [{ list: 'ordered' }, { list: 'bullet' }],
            ['link', 'image'],
            ['blockquote', 'code-block'],
            ['clean'],
          ],
          handlers: {
            image: function() {
              const url = prompt('Image URL:');
              if (url) {
                const range = quillEditor.getSelection();
                quillEditor.insertEmbed(range?.index || 0, 'image', url);
              }
            }
          }
        },
      },
    });
  }

  toggleBtn.addEventListener('click', () => {
    isMarkdownMode = !isMarkdownMode;
    if (isMarkdownMode) {
      quillWrapper.style.display = 'none';
      markdownEditor.style.display = '';
      markdownEditor.value = postSourceMarkdown;
      toggleBtn.textContent = 'Switch to Rich Text';
    } else {
      quillWrapper.style.display = '';
      markdownEditor.style.display = 'none';
      postSourceMarkdown = markdownEditor.value;
      quillEditor.root.innerHTML = markdownToHtml(postSourceMarkdown);
      toggleBtn.textContent = 'Switch to Markdown';
    }
  });

  function markdownToHtml(md: string): string {
    // Protect LaTeX blocks from marked's processing
    const blocks: string[] = [];
    // Block math first ($$...$$)
    let protected_ = md.replace(/\$\$([\s\S]*?)\$\$/g, (_, latex) => {
      blocks.push('$$' + latex + '$$');
      return `%%LATEX_BLOCK_${blocks.length - 1}%%`;
    });
    // Inline math ($...$)
    protected_ = protected_.replace(/\$([^\$\n]+?)\$/g, (_, latex) => {
      blocks.push('$' + latex + '$');
      return `%%LATEX_BLOCK_${blocks.length - 1}%%`;
    });

    let html = (window as any).marked.parse(protected_);

    // Restore LaTeX blocks (use function replacer to avoid $$ special pattern)
    blocks.forEach((latex, i) => {
      html = html.replace(`%%LATEX_BLOCK_${i}%%`, () => latex);
    });

    return html;
  }

  function getPostBody(): string {
    if (isMarkdownMode) {
      return markdownToHtml(markdownEditor.value);
    }
    return quillEditor.root.innerHTML;
  }

  function getPostMarkdown(): string {
    if (isMarkdownMode) return markdownEditor.value;
    return postSourceMarkdown;
  }

  async function loadPostsList() {
    try {
      const data = await api.getPosts();
      const posts = data.posts || [];
      if (posts.length === 0) {
        postsList.innerHTML = '<p style="color:var(--text-muted);font-family:var(--font-mono);font-size:var(--size-sm);">No posts yet.</p>';
        return;
      }
      postsList.innerHTML = posts.map((p: any) => `
        <div class="admin-post-item" style="display:flex;justify-content:space-between;align-items:center;padding:var(--space-md);border-bottom:1px solid var(--border-subtle);cursor:pointer;" data-edit-post="${p.postId}">
          <div>
            <strong style="color:var(--text-primary);">${p.title}</strong>
            <span style="font-family:var(--font-mono);font-size:var(--size-xs);color:var(--text-muted);margin-left:var(--space-sm);">${p.status}</span>
            <div style="font-size:var(--size-xs);color:var(--text-muted);margin-top:var(--space-xs);">${new Date(p.createdAt).toLocaleDateString()}</div>
          </div>
        </div>
      `).join('');

      postsList.querySelectorAll<HTMLElement>('[data-edit-post]').forEach(el => {
        el.addEventListener('click', () => openPostEditor(el.dataset.editPost!));
      });
    } catch (err: any) {
      postsList.innerHTML = `<p class="admin-error">${err.message}</p>`;
    }
  }

  async function openPostEditor(postId?: string) {
    initQuill();
    postsListView.style.display = 'none';
    postEditorView.style.display = 'block';
    const deleteBtn = document.getElementById('delete-post-btn')!;

    // Reset to rich text mode
    isMarkdownMode = false;
    quillWrapper.style.display = '';
    markdownEditor.style.display = 'none';
    toggleBtn.textContent = 'Switch to Markdown';

    if (postId) {
      editingPostId = postId;
      deleteBtn.style.display = '';
      const post = await api.getPost(postId);
      (document.getElementById('post-title') as HTMLInputElement).value = post.title || '';
      (document.getElementById('post-excerpt') as HTMLTextAreaElement).value = post.excerpt || '';
      (document.getElementById('post-status') as HTMLSelectElement).value = post.status || 'draft';
      postSourceMarkdown = post.markdown || '';
      if (postSourceMarkdown) {
        isMarkdownMode = true;
        quillWrapper.style.display = 'none';
        markdownEditor.style.display = '';
        markdownEditor.value = postSourceMarkdown;
        toggleBtn.textContent = 'Switch to Rich Text';
      }
      quillEditor.root.innerHTML = post.body || '';
    } else {
      editingPostId = null;
      deleteBtn.style.display = 'none';
      (document.getElementById('post-title') as HTMLInputElement).value = '';
      (document.getElementById('post-excerpt') as HTMLTextAreaElement).value = '';
      (document.getElementById('post-status') as HTMLSelectElement).value = 'draft';
      postSourceMarkdown = '';
      quillEditor.root.innerHTML = '';
      markdownEditor.value = '';
    }
  }

  document.getElementById('new-post-btn')!.addEventListener('click', () => openPostEditor());

  document.getElementById('back-to-posts')!.addEventListener('click', () => {
    postEditorView.style.display = 'none';
    postsListView.style.display = 'block';
    loadedSections.delete('writing');
    loadPostsList();
  });

  document.getElementById('save-post-btn')!.addEventListener('click', async () => {
    const statusEl = document.getElementById('post-save-status')!;
    const data = {
      title: (document.getElementById('post-title') as HTMLInputElement).value,
      excerpt: (document.getElementById('post-excerpt') as HTMLTextAreaElement).value,
      body: getPostBody(),
      markdown: getPostMarkdown(),
      status: (document.getElementById('post-status') as HTMLSelectElement).value,
    };
    try {
      if (editingPostId) {
        await api.updatePost(editingPostId, data);
      } else {
        const post = await api.createPost(data);
        editingPostId = post.postId;
        document.getElementById('delete-post-btn')!.style.display = '';
      }
      statusEl.textContent = 'Saved.';
      statusEl.className = 'admin-success';
      statusEl.style.display = '';
    } catch (err: any) {
      statusEl.textContent = err.message;
      statusEl.className = 'admin-error';
      statusEl.style.display = '';
    }
  });

  document.getElementById('delete-post-btn')!.addEventListener('click', async () => {
    if (!editingPostId || !confirm('Delete this post?')) return;
    await api.deletePost(editingPostId);
    editingPostId = null;
    postEditorView.style.display = 'none';
    postsListView.style.display = 'block';
    loadedSections.delete('writing');
    await loadPostsList();
  });

  // ── Init ──
  showView();
</script>
</body>
</html>
