---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
import { AWS_CONFIG } from '../lib/aws-config';

const defaults = {
  heroLabel: 'W. Bryan Smith, PhD',
  heroTitle: 'Data, AI,\nand the science\nbetween.',
  heroSub: 'Building at the intersection of neuroscience, AI, and the systems that connect them to real decisions.',
  aboutParagraphs: [] as string[],
  roles: [] as any[],
  expertise: [] as any[],
};

let content = defaults;
try {
  const res = await fetch(`${AWS_CONFIG.apiUrl}/api/content/home`);
  if (res.ok) {
    const data = await res.json();
    content = { ...defaults, ...data.content };
  }
} catch {}

const titleLines = content.heroTitle.split('\n');
const titleAccent = titleLines.pop() || '';

const defaultRoles = [
  { date: '2025 – Present', role: 'Co-Founder & CTO', org: 'Earthineering', desc: 'Building at the intersection of AI, earth sciences, and engineering.', accent: 'cyan' },
  { date: '2022 – 2025', role: 'Group Director, Infrastructure & AI', org: 'Walmart Global Tech', desc: 'Led identity, interoperability, information management, and AI for Health & Wellness.', accent: 'magenta' },
  { date: '2017 – 2022', role: 'Co-Founder & CTO', org: 'Myia Labs', desc: 'Built an intelligent health platform for monitoring and engaging patients with chronic conditions.', accent: 'amber' },
  { date: '2012 – 2018', role: 'Chief Scientist', org: 'PokitDok', desc: 'Healthcare transaction platform — consumer marketplace, claims, provider networks, pricing intelligence.', accent: 'coral' },
  { date: '1998 – 2004', role: 'PhD, Neuroscience', org: 'California Institute of Technology', desc: 'Molecular and cellular neurobiology. Local control of synaptic strength via dendritic protein synthesis.', accent: 'blue' },
];
const roles = content.roles?.length ? content.roles : defaultRoles;

const defaultExpertise = [
  { title: 'AI & Machine Learning', desc: 'Statistical modeling, NLP, computer vision, recommendation systems, predictive analytics. From Bayesian networks to transformer architectures.', tags: ['Python', 'PyTorch', 'Scikit-learn', 'NLP', 'Computer Vision'], accent: 'cyan' },
  { title: 'Data & Infrastructure', desc: 'End-to-end data strategy — pipelines, warehousing, governance, APIs, integrations. Building data organizations from the ground up.', tags: ['AWS', 'Spark', 'SQL', 'Kafka', 'Airflow'], accent: 'magenta' },
  { title: 'Visualization & Communication', desc: 'Interactive data visualization, scientific communication, translating complex technical work for executives and stakeholders.', tags: ['D3.js', 'Observable', 'Gephi', 'R', 'Julia'], accent: 'amber' },
];
const expertise = content.expertise?.length ? content.expertise : defaultExpertise;
---

<Base title="W. Bryan Smith">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__grid">
        <div class="hero__text">
          <p class="hero__label" data-content="heroLabel">{content.heroLabel}</p>
          <h1 class="hero__title" data-content="heroTitle">
            {titleLines.map(line => <>{line}<br /></>)}
            <span class="hero__accent">{titleAccent}</span>
          </h1>
          <p class="hero__sub" data-content="heroSub">{content.heroSub}</p>
        </div>
        <div class="hero__photo">
          <div class="hero__photo-frame">
            <img src="/headshot_website.jpg" alt="W. Bryan Smith" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section">
    <div class="container container--narrow">
      <div class="section__header">
        <span class="section__label">About</span>
        <h2 class="section__title">Background</h2>
        <hr class="section__divider" />
      </div>
      <div class="about__body" data-content="aboutParagraphs">
        {content.aboutParagraphs.length > 0
          ? content.aboutParagraphs.map(p => <p>{p}</p>)
          : <>
              <p>I'm a multidisciplinary technical leader with a career that started in the wet lab and moved through computational neuroscience, data science, machine learning engineering, and executive leadership. PhD from Caltech in neuroscience, where I studied local protein synthesis in hippocampal neurons. That training — designing experiments, building models from first principles, communicating findings clearly — has shaped everything I've done since.</p>
              <p>I've held technical and executive roles across biotech, healthcare, gaming, market research, and enterprise retail. Currently Co-Founder and CTO at Earthineering. Previously CDO at Sequoia, led identity, interoperability, and AI for Walmart Health & Wellness, co-founded Myia Labs (an intelligent health monitoring platform), and served as Chief Scientist at PokitDok.</p>
              <p>I build things outside of work too — four independent web products, each addressing a different problem I cared enough to solve. I also photograph landscapes and cityscapes, and I spend a lot of time on trails.</p>
            </>
        }
      </div>
    </div>
  </section>

  <!-- Career highlights -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="section__header">
        <span class="section__label">Career</span>
        <h2 class="section__title">Selected roles</h2>
        <hr class="section__divider" />
      </div>
      <div class="timeline" id="roles-container">
        {roles.map((r: any, i: number) => (
          <div class="timeline__item">
            <div class="timeline__marker" style={`--accent: var(--${r.accent || 'cyan'});`}></div>
            <div class="timeline__content">
              <span class="timeline__date">{r.date}</span>
              <h3 class="timeline__role">{r.role}</h3>
              <span class="timeline__org">{r.org}</span>
              <p>{r.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Expertise -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="section__label">Expertise</span>
        <h2 class="section__title">What I work with</h2>
        <hr class="section__divider" />
      </div>
      <div class="grid grid--3" id="expertise-container">
        {expertise.map((e: any) => (
          <div class={`card card--accent-${e.accent || 'cyan'}`}>
            <h4>{e.title}</h4>
            <p>{e.desc}</p>
            <div class="tag-group">
              {(e.tags || []).map((t: string) => <span class="tag">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Interests -->
  <section class="section">
    <div class="container container--narrow">
      <div class="section__header">
        <span class="section__label">Outside work</span>
        <h2 class="section__title">Interests</h2>
        <hr class="section__divider" />
      </div>
      <div class="interests">
        <div class="interest">
          <h4>Photography</h4>
          <p>
            Landscapes, macro, and abstract photography — often inspired by
            my home state of California. My gallery lives at
            <a href="https://picgraf.com" target="_blank" rel="noopener">picgraf.com</a>.
          </p>
        </div>
        <div class="interest">
          <h4>Trail Running</h4>
          <p>
            The best way to think through a hard problem is on a trail
            with no cell service.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ContactForm />
</Base>

<script>
  import { api } from '../lib/api-client';

  async function refreshHome() {
    try {
      const data = await api.getContent('home');
      const c = data.content;
      if (!c) return;

      // Roles
      if (c.roles?.length) {
        const container = document.getElementById('roles-container');
        if (container) {
          container.innerHTML = c.roles.map((r: any) => `
            <div class="timeline__item">
              <div class="timeline__marker" style="--accent: var(--${r.accent || 'cyan'});"></div>
              <div class="timeline__content">
                <span class="timeline__date">${r.date}</span>
                <h3 class="timeline__role">${r.role}</h3>
                <span class="timeline__org">${r.org}</span>
                <p>${r.desc}</p>
              </div>
            </div>
          `).join('');
        }
      }

      // Expertise
      if (c.expertise?.length) {
        const container = document.getElementById('expertise-container');
        if (container) {
          container.innerHTML = c.expertise.map((e: any) => `
            <div class="card card--accent-${e.accent || 'cyan'}">
              <h4>${e.title}</h4>
              <p>${e.desc}</p>
              <div class="tag-group">
                ${(e.tags || []).map((t: string) => `<span class="tag">${t}</span>`).join('')}
              </div>
            </div>
          `).join('');
        }
      }
    } catch {}
  }
  refreshHome();
</script>

<style is:global>
  .hero {
    position: relative;
    z-index: 1;
    padding: var(--space-4xl) 0 var(--space-3xl);
    border-bottom: 1px solid var(--border-subtle);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero__label {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--cyan);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .hero__title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-xl);
  }

  .hero__accent {
    background: linear-gradient(135deg, var(--cyan), var(--magenta));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__sub {
    font-size: var(--size-lg);
    color: var(--text-secondary);
    max-width: 36rem;
    line-height: 1.6;
  }

  .hero__photo {
    flex-shrink: 0;
  }

  .hero__photo-frame {
    width: 240px;
    aspect-ratio: 1059 / 1186;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-medium);
    background: var(--bg-surface);
  }

  .hero__photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left center;
  }

  @media (max-width: 768px) {
    .hero__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero__sub {
      margin: 0 auto;
    }

    .hero__photo {
      display: none;
    }
  }

  .about__body {
    font-size: var(--size-lg);
    line-height: 1.8;
  }

  .about__body p {
    color: var(--text-secondary);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: var(--content-width);
  }

  .timeline__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-lg);
  }

  .timeline__marker {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent, var(--cyan));
    margin-top: 0.5rem;
    position: relative;
    flex-shrink: 0;
  }

  .timeline__marker::after {
    content: '';
    position: absolute;
    top: 14px;
    left: 4px;
    width: 2px;
    height: calc(100% + var(--space-xl) - 4px);
    background: var(--border-subtle);
  }

  .timeline__item:last-child .timeline__marker::after {
    display: none;
  }

  .timeline__date {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-muted);
  }

  .timeline__role {
    font-size: var(--size-xl);
    margin: var(--space-xs) 0;
  }

  .timeline__org {
    font-size: var(--size-sm);
    color: var(--text-muted);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .timeline__content p {
    font-size: var(--size-sm);
    color: var(--text-secondary);
  }

  .tag-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .interests {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .interest h4 {
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
  }

  .interest p {
    font-size: var(--size-lg);
    color: var(--text-secondary);
  }
</style>
