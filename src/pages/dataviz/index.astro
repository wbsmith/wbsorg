---
import Base from '../../layouts/Base.astro';
---

<Base title="Data Viz — W. Bryan Smith">
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="section__label">Data Visualization</span>
        <h1 class="section__title">Data Viz</h1>
        <p class="dataviz__intro">
          Interactive visualizations, exploratory analyses, and the occasional
          video walkthrough. A mix of professional work samples and personal
          explorations.
        </p>
        <hr class="section__divider" />
      </div>
      <div class="dataviz__grid">
        {[0,1,2,3,4,5].map(i => (
          <div class="dataviz__slot" data-viz-slot={i}>
            <div class="dataviz__empty-slot">
              <span class="dataviz__slot-num">{i + 1}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  import { api } from '../../lib/api-client';

  async function loadViz() {
    try {
      const data = await api.getContent('dataviz');
      if (!data.content?.slots) return;
      data.content.slots.forEach((slot: any, i: number) => {
        if (!slot?.url) return;
        const el = document.querySelector(`[data-viz-slot="${i}"]`);
        if (!el) return;
        if (slot.type === 'image') {
          el.innerHTML = `<img src="${slot.url}" alt="${slot.title || ''}" loading="lazy" />
            ${slot.title ? `<span class="dataviz__caption">${slot.title}</span>` : ''}`;
        } else if (slot.type === 'video') {
          el.innerHTML = `<video src="${slot.url}" controls></video>
            ${slot.title ? `<span class="dataviz__caption">${slot.title}</span>` : ''}`;
        } else if (slot.type === 'embed') {
          el.innerHTML = `<iframe src="${slot.url}" title="${slot.title || ''}" loading="lazy"></iframe>
            ${slot.title ? `<span class="dataviz__caption">${slot.title}</span>` : ''}`;
        }
      });
    } catch { /* keep empty slots */ }
  }
  loadViz();
</script>

<style>
  .dataviz__intro {
    font-size: var(--size-lg);
    color: var(--text-secondary);
    max-width: 40rem;
    margin-top: var(--space-md);
  }

  .dataviz__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  @media (max-width: 1024px) {
    .dataviz__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .dataviz__grid { grid-template-columns: 1fr; }
  }

  .dataviz__slot {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    position: relative;
  }

  .dataviz__slot img,
  .dataviz__slot video,
  .dataviz__slot iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none;
  }

  .dataviz__empty-slot {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dataviz__slot-num {
    font-family: var(--font-mono);
    font-size: var(--size-3xl);
    color: var(--border-subtle);
  }

  .dataviz__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-sm) var(--space-md);
    background: rgba(6, 6, 11, 0.8);
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-secondary);
  }
</style>
