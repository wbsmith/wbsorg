---
import Base from '../../layouts/Base.astro';
---

<Base title="Data Viz — W. Bryan Smith" ogPage="dataviz">
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="section__label">Data Visualization</span>
        <h1 class="section__title">Data Viz</h1>
        <p class="dataviz__intro">
          Interactive visualizations, exploratory analyses, and the occasional
          video walkthrough. A mix of professional work samples and personal
          explorations.
        </p>
        <hr class="section__divider" />
      </div>
      <div class="dataviz__grid" id="dataviz-grid">
        {[0,1,2,3,4,5].map(i => (
          <div class="dataviz__slot" data-viz-slot={i}>
            <div class="dataviz__empty-slot">
              <span class="dataviz__slot-num">{i + 1}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <dialog class="dataviz__modal" id="dataviz-modal">
    <div class="dataviz__modal-header">
      <button class="dataviz__modal-close" id="dataviz-modal-close" aria-label="Close">&times;</button>
    </div>
    <div class="dataviz__modal-body" id="dataviz-modal-body"></div>
  </dialog>
</Base>

<script>
  import { api } from '../../lib/api-client';

  function detectType(url: string): string {
    const lower = url.toLowerCase();
    if (lower.endsWith('.html') || lower.endsWith('.htm')) return 'html';
    if (lower.endsWith('.mp4') || lower.endsWith('.webm') || lower.endsWith('.mov')) return 'video';
    return 'image';
  }

  function renderSlot(el: Element, slot: any) {
    const url = typeof slot === 'string' ? slot : slot.url;
    const caption = typeof slot === 'string' ? '' : (slot.caption || '');
    const description = typeof slot === 'string' ? '' : (slot.description || '');
    const type = detectType(url);
    const cw = (typeof slot !== 'string' && slot.width) || 1024;
    const ch = (typeof slot !== 'string' && slot.height) || 768;

    el.classList.add('dataviz__slot--filled');
    el.setAttribute('data-viz-url', url);
    el.setAttribute('data-viz-type', type);
    if (caption) el.setAttribute('data-viz-caption', caption);
    if (description) el.setAttribute('data-viz-desc', description);
    el.setAttribute('data-viz-w', String(cw));
    el.setAttribute('data-viz-h', String(ch));

    const captionHtml = caption ? `<div class="dataviz__caption">${caption}</div>` : '';

    if (type === 'html') {
      el.innerHTML = `<iframe src="${url}"></iframe>${captionHtml}`;
      scaleIframeInSlot(el as HTMLElement, cw, ch);
    } else if (type === 'video') {
      el.innerHTML = `<video src="${url}" muted loop autoplay playsinline></video>${captionHtml}`;
    } else {
      el.innerHTML = `<img src="${url}" alt="${caption}" loading="lazy" />${captionHtml}`;
    }
  }

  function scaleIframeInSlot(slot: Element, iw: number, ih: number) {
    const iframe = slot.querySelector('iframe') as HTMLIFrameElement;
    if (!iframe) return;
    iframe.style.width = `${iw}px`;
    iframe.style.height = `${ih}px`;

    const apply = () => {
      const el = slot as HTMLElement;
      const w = el.clientWidth;
      const h = el.clientHeight;
      if (w > 0 && h > 0) {
        iframe.style.transform = `scale(${Math.min(w / iw, h / ih)})`;
      }
    };

    const ro = new ResizeObserver(() => apply());
    ro.observe(slot as HTMLElement);
    iframe.addEventListener('load', apply);
  }

  async function loadViz() {
    try {
      const data = await api.getContent('dataviz');
      if (!data.content?.slots) return;
      data.content.slots.forEach((slot: any, i: number) => {
        if (!slot) return;
        const url = typeof slot === 'string' ? slot : slot?.url;
        if (!url) return;
        const el = document.querySelector(`[data-viz-slot="${i}"]`);
        if (el) renderSlot(el, slot);
      });
    } catch { /* keep empty slots */ }
  }

  // Fullscreen modal
  const modal = document.getElementById('dataviz-modal') as HTMLDialogElement;
  const modalBody = document.getElementById('dataviz-modal-body')!;
  const modalClose = document.getElementById('dataviz-modal-close')!;

  document.getElementById('dataviz-grid')!.addEventListener('click', (e) => {
    const slot = (e.target as HTMLElement).closest('.dataviz__slot--filled') as HTMLElement | null;
    if (!slot) return;

    const url = slot.getAttribute('data-viz-url')!;
    const type = slot.getAttribute('data-viz-type')!;
    const caption = slot.getAttribute('data-viz-caption') || '';
    const description = slot.getAttribute('data-viz-desc') || '';
    const vizW = parseInt(slot.getAttribute('data-viz-w') || '1024');
    const vizH = parseInt(slot.getAttribute('data-viz-h') || '768');

    let media = '';
    if (type === 'html') {
      const ar = vizW / vizH;
      media = `<iframe src="${url}" class="dataviz__modal-iframe" style="aspect-ratio:${ar}; max-height:100%; max-width:100%;"></iframe>`;
    } else if (type === 'video') {
      media = `<video src="${url}" controls autoplay class="dataviz__modal-media"></video>`;
    } else {
      media = `<img src="${url}" alt="" class="dataviz__modal-media" />`;
    }

    if (caption || description) {
      modalBody.innerHTML = `
        <div class="dataviz__modal-split">
          <div class="dataviz__modal-info">
            ${caption ? `<h3>${caption}</h3>` : ''}
            ${description ? `<p>${description}</p>` : ''}
          </div>
          <div class="dataviz__modal-content">${media}</div>
        </div>`;
    } else {
      modalBody.innerHTML = `<div class="dataviz__modal-content dataviz__modal-content--full">${media}</div>`;
    }

    modal.showModal();
  });

  modalClose.addEventListener('click', () => {
    modalBody.innerHTML = '';
    modal.close();
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      modalBody.innerHTML = '';
      modal.close();
    }
  });

  loadViz();
</script>

<style is:global>
  .dataviz__intro {
    font-size: var(--size-lg);
    color: var(--text-secondary);
    max-width: 40rem;
    margin-top: var(--space-md);
  }

  .dataviz__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  @media (max-width: 1024px) {
    .dataviz__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .dataviz__grid { grid-template-columns: 1fr; }
  }

  .dataviz__slot {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    position: relative;
  }

  .dataviz__slot--filled {
    cursor: pointer;
  }

  .dataviz__slot img,
  .dataviz__slot video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: var(--bg-surface);
    border: none;
  }

  .dataviz__slot iframe {
    width: 1024px;
    height: 768px;
    border: none;
    pointer-events: none;
    transform-origin: 0 0;
    position: absolute;
    top: 0;
    left: 0;
    background: #fff;
  }

  .dataviz__empty-slot {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dataviz__slot-num {
    font-family: var(--font-mono);
    font-size: var(--size-3xl);
    color: var(--border-subtle);
  }

  .dataviz__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-sm) var(--space-md);
    background: rgba(6, 6, 11, 0.85);
    font-size: var(--size-sm);
    color: var(--text-secondary);
    line-height: 1.4;
    z-index: 1;
  }

  /* Modal */
  .dataviz__modal {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: rgba(6, 6, 11, 0.95);
    z-index: 300;
  }

  .dataviz__modal::backdrop {
    background: transparent;
  }

  .dataviz__modal-header {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    z-index: 10;
  }

  .dataviz__modal-close {
    font-size: 2rem;
    color: var(--text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
    padding: var(--space-sm);
  }

  .dataviz__modal-close:hover {
    color: var(--text-primary);
  }

  .dataviz__modal-body {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3xl);
    overflow: hidden;
  }

  .dataviz__modal-iframe {
    width: 100%;
    height: 100%;
    border: none;
    border-radius: var(--radius-md);
    background: #fff;
  }

  .dataviz__modal-media {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: var(--radius-md);
  }

  .dataviz__modal-split {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-2xl);
    width: 100%;
    height: 100%;
    min-height: 0;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .dataviz__modal-split {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
    }
  }

  .dataviz__modal-info {
    color: var(--text-secondary);
    line-height: 1.7;
    align-self: center;
    overflow-y: auto;
  }

  .dataviz__modal-info h3 {
    font-size: var(--size-xl);
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .dataviz__modal-info p {
    font-size: var(--size-base);
  }

  .dataviz__modal-content {
    min-height: 0;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dataviz__modal-content--full {
    width: 100%;
    height: 100%;
  }

  .dataviz__modal-iframe {
    width: 100%;
    height: 100%;
    border: none;
    border-radius: var(--radius-md);
    background: #fff;
  }

  .dataviz__modal-media {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: var(--radius-md);
  }
</style>
