---
import Base from '../../layouts/Base.astro';
---

<Base title="Data Viz — W. Bryan Smith">
  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="section__label">Data Visualization</span>
        <h1 class="section__title">Data Viz</h1>
        <p class="dataviz__intro">
          Interactive visualizations, exploratory analyses, and the occasional
          video walkthrough. A mix of professional work samples and personal
          explorations.
        </p>
        <hr class="section__divider" />
      </div>
      <div class="dataviz__grid" id="dataviz-grid">
        {[0,1,2,3,4,5].map(i => (
          <div class="dataviz__slot" data-viz-slot={i}>
            <div class="dataviz__empty-slot">
              <span class="dataviz__slot-num">{i + 1}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <dialog class="dataviz__modal" id="dataviz-modal">
    <div class="dataviz__modal-header">
      <button class="dataviz__modal-close" id="dataviz-modal-close" aria-label="Close">&times;</button>
    </div>
    <div class="dataviz__modal-body" id="dataviz-modal-body"></div>
  </dialog>
</Base>

<script>
  import { api } from '../../lib/api-client';

  function detectType(url: string): string {
    const lower = url.toLowerCase();
    if (lower.endsWith('.html') || lower.endsWith('.htm')) return 'html';
    if (lower.endsWith('.mp4') || lower.endsWith('.webm') || lower.endsWith('.mov')) return 'video';
    return 'image';
  }

  function renderSlot(el: Element, slot: any) {
    const url = typeof slot === 'string' ? slot : slot.url;
    const caption = typeof slot === 'string' ? '' : (slot.caption || '');
    const type = detectType(url);
    el.classList.add('dataviz__slot--filled');
    el.setAttribute('data-viz-url', url);
    el.setAttribute('data-viz-type', type);

    const captionHtml = caption ? `<div class="dataviz__caption">${caption}</div>` : '';
    let content = '';

    if (type === 'html') {
      content = `<iframe src="${url}" class="dataviz__iframe" loading="lazy"></iframe>`;
    } else if (type === 'video') {
      content = `<video src="${url}" muted loop autoplay playsinline></video>`;
    } else if (/\.svg$/i.test(url)) {
      content = `<object data="${url}" type="image/svg+xml" class="dataviz__svg"></object>`;
    } else {
      content = `<img src="${url}" alt="${caption}" loading="lazy" />`;
    }

    el.innerHTML = content + captionHtml;

    if (type === 'html') {
      const iframe = el.querySelector('iframe')!;
      const doScale = () => {
        const w = el.clientWidth;
        if (w > 0) {
          const scale = w / 1024;
          iframe.style.transform = `scale(${scale})`;
        }
      };
      iframe.addEventListener('load', doScale);
      setTimeout(doScale, 100);
      window.addEventListener('resize', doScale);
    }
  }

  async function loadViz() {
    try {
      const data = await api.getContent('dataviz');
      if (!data.content?.slots) return;
      data.content.slots.forEach((slot: any, i: number) => {
        if (!slot) return;
        const url = typeof slot === 'string' ? slot : slot?.url;
        if (!url) return;
        const el = document.querySelector(`[data-viz-slot="${i}"]`);
        if (el) renderSlot(el, slot);
      });
    } catch { /* keep empty slots */ }
  }

  // Fullscreen modal
  const modal = document.getElementById('dataviz-modal') as HTMLDialogElement;
  const modalBody = document.getElementById('dataviz-modal-body')!;
  const modalClose = document.getElementById('dataviz-modal-close')!;

  document.getElementById('dataviz-grid')!.addEventListener('click', (e) => {
    const slot = (e.target as HTMLElement).closest('.dataviz__slot--filled') as HTMLElement | null;
    if (!slot) return;

    const url = slot.getAttribute('data-viz-url')!;
    const type = slot.getAttribute('data-viz-type')!;

    if (type === 'html') {
      modalBody.innerHTML = `<iframe src="${url}" class="dataviz__modal-iframe"></iframe>`;
    } else if (type === 'video') {
      modalBody.innerHTML = `<video src="${url}" controls autoplay class="dataviz__modal-media"></video>`;
    } else {
      modalBody.innerHTML = `<img src="${url}" alt="" class="dataviz__modal-media" />`;
    }

    modal.showModal();
  });

  modalClose.addEventListener('click', () => {
    modalBody.innerHTML = '';
    modal.close();
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      modalBody.innerHTML = '';
      modal.close();
    }
  });

  loadViz();
</script>

<style>
  .dataviz__intro {
    font-size: var(--size-lg);
    color: var(--text-secondary);
    max-width: 40rem;
    margin-top: var(--space-md);
  }

  .dataviz__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  @media (max-width: 1024px) {
    .dataviz__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .dataviz__grid { grid-template-columns: 1fr; }
  }

  .dataviz__slot {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    position: relative;
  }

  .dataviz__slot--filled {
    cursor: pointer;
  }

  .dataviz__slot img,
  .dataviz__slot video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: var(--bg-surface);
    border: none;
  }

  .dataviz__svg {
    width: 100%;
    height: 100%;
  }

  .dataviz__iframe {
    width: 1024px;
    height: 768px;
    border: none;
    transform-origin: 0 0;
    position: absolute;
    top: 0;
    left: 0;
    background: #fff;
    pointer-events: none;
  }

  .dataviz__empty-slot {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dataviz__slot-num {
    font-family: var(--font-mono);
    font-size: var(--size-3xl);
    color: var(--border-subtle);
  }

  .dataviz__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-sm) var(--space-md);
    background: rgba(6, 6, 11, 0.85);
    font-size: var(--size-sm);
    color: var(--text-secondary);
    line-height: 1.4;
    z-index: 1;
  }

  /* Modal */
  .dataviz__modal {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: rgba(6, 6, 11, 0.95);
    z-index: 300;
  }

  .dataviz__modal::backdrop {
    background: transparent;
  }

  .dataviz__modal-header {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    z-index: 10;
  }

  .dataviz__modal-close {
    font-size: 2rem;
    color: var(--text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
    padding: var(--space-sm);
  }

  .dataviz__modal-close:hover {
    color: var(--text-primary);
  }

  .dataviz__modal-body {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3xl);
  }

  .dataviz__modal-iframe {
    width: 100%;
    height: 100%;
    border: none;
    border-radius: var(--radius-md);
    background: #fff;
  }

  .dataviz__modal-media {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: var(--radius-md);
  }
</style>
